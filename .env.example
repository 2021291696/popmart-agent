# 泡泡玛特 Agent - LLM 配置示例
# 复制此文件为 .env,填入你的凭据。也可以在启动后通过 UI 表单配置(存到 .user_config.json)。
#
# 支持两种 provider,任选其一:

# === 方案 A: MiniMax(anthropic 协议,推荐)===
LLM_PROVIDER=anthropic
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_MODEL=claude-sonnet-4-6
MINIMAX_API_KEY=sk-...

# === 方案 B: DeepSeek(openai 协议)===
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=sk-...

# === 方案 C: OpenAI 官方 ===
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# === Streamlit 登录（可选；设置后强制登录，忽略 ALLOW_LOCAL_DEV 绕过）===
# STREAMLIT_USER=admin
# STREAMLIT_PASSWORD=change-me
# AUTH_MAX_FAILURES=5
# AUTH_LOCKOUT_SECONDS=60
